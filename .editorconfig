root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{cs,csproj,props}]

# --------------------------------------------------
# Qualification preferences
# --------------------------------------------------

dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# --------------------------------------------------
# var preferences
# --------------------------------------------------

csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# --------------------------------------------------
# Expression-bodied members
# --------------------------------------------------

csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# --------------------------------------------------
# Namespace preferences
# --------------------------------------------------

csharp_style_namespace_declarations = file_scoped:suggestion

# --------------------------------------------------
# Braces / indentation
# --------------------------------------------------

csharp_prefer_braces = true:suggestion
csharp_new_line_before_open_brace = all

csharp_indent_case_contents = true
csharp_indent_switch_labels = true

# --------------------------------------------------
# Diagnostics
# --------------------------------------------------

dotnet_diagnostic.IDE0005.severity = warning

# --------------------------------------------------
# Line length
# --------------------------------------------------

max_line_length = 120
resharper_csharp_max_line_length = 120

# --------------------------------------------------
# Argument / parameter wrapping
# --------------------------------------------------

resharper_csharp_wrap_arguments_style = chop_if_long
resharper_csharp_wrap_parameters_style = chop_if_long

resharper_csharp_wrap_after_invocation_lpar = true
resharper_csharp_wrap_before_comma = false

# --------------------------------------------------
# LINQ / chained method formatting
# --------------------------------------------------

resharper_csharp_wrap_chained_method_calls = chop_if_long
resharper_csharp_wrap_before_linq_expression = true

# --------------------------------------------------
# Object / collection initializer formatting
# --------------------------------------------------

resharper_csharp_initializer_wrap_style = chop_if_long
resharper_csharp_wrap_object_and_collection_initializer_style = chop_if_long

# Never keep initializers on one line
resharper_csharp_place_simple_initializer_on_single_line = false
resharper_csharp_place_initializer_on_single_line = false

# Preserve useful manual line breaks
resharper_csharp_keep_user_linebreaks = true

# --------------------------------------------------
# Misc formatting
# --------------------------------------------------

resharper_csharp_place_accessorholder_attribute_on_same_line = false
resharper_csharp_place_simple_property_pattern_on_single_line = false

# Collection/object initializer formatting
resharper_csharp_wrap_object_and_collection_initializer_style = chop_if_long
resharper_csharp_initializer_wrap_style = chop_if_long

# Never keep collection initializers on one line
resharper_csharp_place_simple_initializer_on_single_line = false
resharper_csharp_place_initializer_on_single_line = false

# Put each item on its own line
resharper_csharp_max_array_initializer_elements_on_line = 1