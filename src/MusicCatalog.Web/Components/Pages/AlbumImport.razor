@page "/album-import"
@using MusicCatalog.Contracts.Albums
@using MusicCatalog.ExternalMetadata
@using MusicCatalog.Importing
@rendermode InteractiveServer
@inject IMusicMetadataService MusicService
@inject IAlbumImportService AlbumImportService

<h3>Add Album</h3>

<div class="container mt-4">

    <div class="card mb-4">
        <div class="card-body">
            <label class="form-label">Album name</label>

            <div class="input-group">
                <input class="form-control"
                       placeholder="Search for an album..."
                       @bind="searchTerm"/>

                <button class="btn btn-primary" @onclick="SearchAlbums">
                    Search
                </button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">Searching MusicBrainz...</div>
    }

    @if (searchResults.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                Search Results
            </div>

            <div class="list-group list-group-flush">
                @foreach (var album in searchResults)
                {
                    <button class="list-group-item list-group-item-action"
                            @onclick="() => SelectAlbum(album)">
                        <strong>@album.Title</strong><br/>
                        <span>@album.ArtistName</span><br/>
                        <small class="text-muted">
                            @album.ReleaseDate · @album.TrackCount tracks
                        </small>
                    </button>
                }
            </div>
        </div>
    }

    @if (selectedAlbum is not null)
    {
        <div class="card mb-4">
            <div class="card-header">
                Album Preview
            </div>

            <div class="card-body">
                <h5>@selectedAlbum.Title</h5>
                <p class="mb-1">
                    <strong>Artist:</strong> @selectedAlbum.ArtistName
                </p>
                <p class="mb-3">
                    <strong>Release date:</strong> @selectedAlbum.ReleaseDate
                </p>

                <h6>Tracks</h6>

                <ol>
                    @foreach (var track in selectedAlbum.Tracks)
                    {
                        <li>@track.Title</li>
                    }
                </ol>

                <button class="btn btn-success" @onclick="AddAlbum">
                    Add to Catalogue
                </button>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-secondary">
            @statusMessage
        </div>
    }

</div>

@code {
    private string searchTerm = string.Empty;
    private bool isLoading;
    private string? statusMessage;

    private IReadOnlyList<AlbumSearchResult> searchResults = [];
    private AlbumImportPreview? selectedAlbum;

    private async Task SearchAlbums()
    {
        selectedAlbum = null;
        statusMessage = null;
        isLoading = true;

        searchResults = await MusicService.FindSimpleAlbumsAsync(searchTerm);

        isLoading = false;
    }

    private async Task SelectAlbum(AlbumSearchResult album)
    {
        statusMessage = "Loading full album details...";

        selectedAlbum = await MusicService.LookupAlbumImportPreviewAsync(album.MusicBrainzReleaseId);

        statusMessage = null;
    }

    private async Task AddAlbum()
    {
        if (selectedAlbum is null)
            return;

        statusMessage = "Adding album to database...";

        await AlbumImportService.ImportAlbumAsync(selectedAlbum);

        statusMessage = $"Added '{selectedAlbum.Title}' to your catalogue.";
    }
}
