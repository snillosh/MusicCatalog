@page "/login"
@using System.ComponentModel.DataAnnotations
@using MusicCatalog.ApiClient
@using MusicCatalog.Contracts.Authentication
@using MusicCatalog.Web.Auth
@rendermode InteractiveServer
@inject IAuthApiClient AuthApiClient
@inject IAccessTokenStore TokenStore
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-6 col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h1 class="h3 mb-2">Sign in</h1>
                    <p class="text-muted mb-4">
                        Sign in to manage your music catalog.
                    </p>

                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <div class="alert alert-danger" role="alert">
                            @_error
                        </div>
                    }

                    <EditForm Model="Model" FormName="login" OnValidSubmit="LoginAsync">
                        <DataAnnotationsValidator/>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <InputText id="email"
                                       class="form-control"
                                       type="email"
                                       autocomplete="username"
                                       @bind-Value="Model.Email"/>
                            <ValidationMessage For="() => Model.Email"/>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <InputText id="password"
                                       class="form-control"
                                       type="password"
                                       autocomplete="current-password"
                                       @bind-Value="Model.Password"/>
                            <ValidationMessage For="() => Model.Password"/>
                        </div>

                        <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                                <span>Signing in...</span>
                            }
                            else
                            {
                                <span>Sign in</span>
                            }
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {

    [SupplyParameterFromForm]
    private LoginModel Model { get; set; } = new();

    private bool _isSubmitting;
    private string? _error;

    private async Task LoginAsync()
    {
        _error = null;
        _isSubmitting = true;

        try
        {
            var response = await AuthApiClient.LoginAsync(
            new LoginRequest(Model.Email, Model.Password));

            await TokenStore.SetAccessTokenAsync(response.AccessToken);
            Navigation.NavigateTo("/album-import");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class LoginModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }

}
