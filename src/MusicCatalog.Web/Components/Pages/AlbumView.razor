@page "/album-view"
@using MusicCatalog.ApiClient
@using MusicCatalog.Contracts.Albums
@using MusicCatalog.Contracts.Common.Paging

@inject IAlbumApiClient AlbumApiClient

<div class="container mt-6">
    <div class="row">
        <div class="col-md-6">
            <div class="card mt-6">
                <div class="card-body">
                    <h3>Album view</h3>

                    @if (_dbAlbums is null)
                    {
                        <p>Loading...</p>
                    }
                    else
                    {
                        <ul class="list-group mb-3">
                            @foreach (var album in _dbAlbums.Items)
                            {
                                <button class="list-group-item list-group-item-action"
                                        @onclick="() => SelectAlbum(album)">
                                    <h4>@album.Title</h4>
                                    <h5>@album.ArtistName</h5>
                                    <p>@album.ReleaseYear</p>
                                </button>
                            }
                        </ul>

                        <nav>
                            <ul class="pagination">
                                <li class="page-item @(_dbAlbums.Page <= 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => LoadPage(_dbAlbums.Page - 1)">
                                        Previous
                                    </button>
                                </li>

                                @for (var i = 1; i <= _dbAlbums.TotalPages; i++)
                                {
                                    var pageNumber = i;

                                    <li class="page-item @(pageNumber == _dbAlbums.Page ? "active" : "")">
                                        <button class="page-link" @onclick="() => LoadPage(pageNumber)">
                                            @pageNumber
                                        </button>
                                    </li>
                                }

                                <li class="page-item @(_dbAlbums.Page >= _dbAlbums.TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => LoadPage(_dbAlbums.Page + 1)">
                                        Next
                                    </button>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h3>Album details</h3>

                    @if (_selectedAlbum is null)
                    {
                        <h3>Please selected an album to view details.</h3>
                    }
                    else
                    {
                        <p>Title: @_selectedAlbum.Title</p>
                        <p>Artist: @_selectedAlbum.ArtistName</p>
                        <p>Release Year: @_selectedAlbum.ReleaseYear</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private PagedResult<AlbumListItemDto> _dbAlbums;
    private AlbumListItemDto _selectedAlbum;

    protected async override Task OnInitializedAsync()
    {
        await LoadPage(1);

        await base.OnInitializedAsync();
    }

    private async Task LoadPage(
        int page)
    {
        if (page < 1)
        {
            return;
        }

        _dbAlbums = await AlbumApiClient.GetAlbumsAsync(page);
    }

    private async Task SelectAlbum(
        AlbumListItemDto album)
    {
        _selectedAlbum = album;
    }
}
